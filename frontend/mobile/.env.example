# Скопируйте в .env и подставьте URL API.
# На физическом iPhone localhost недоступен — используйте IP вашего Mac/ПК в LAN, например:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:8000/api
EXPO_PUBLIC_API_BASE_URL=https://api.rexten.live/api

# LAN: зафиксировать IP для Metro (если без Cloudflare):
# EXPO_LAN_IP=192.168.1.5

# Metro через Cloudflare Tunnel (публичный HTTPS → на сервере прокси на http://127.0.0.1:8081):
# EXPO_METRO_HOST=metro.rexten.live
# EXPO_PACKAGER_PROXY_URL=https://metro.rexten.live
