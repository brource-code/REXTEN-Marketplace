# Публичный origin сайта (canonical, OG, sitemap).
NEXT_PUBLIC_SITE_URL=https://rexten.live

# Браузерный API (бандл Next).
NEXT_PUBLIC_LARAVEL_API_URL=https://api.rexten.live/api

# SSR/sitemap в Node (runtime, не инлайнится в клиент — надёжно для продакшена).
LARAVEL_API_URL=https://api.rexten.live/api

# Docker: HTTP к Laravel только через nginx (не rexten_backend — там php-fpm).
INTERNAL_LARAVEL_API_URL=http://nginx/api

# Опционально: переопределить порядок SSR целиком.
# SSR_LARAVEL_API_URL=https://api.rexten.live/api
