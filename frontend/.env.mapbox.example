# Публичный токен Mapbox (pk...) — https://account.mapbox.com/
# Скопируйте нужные строки в frontend/.env.local
#
# Рекомендуется для Docker (next start): переменная без NEXT_PUBLIC_ — подхватывается в runtime
# без пересборки образа после добавления токена (достаточно перезапустить контейнер frontend).
MAPBOX_PUBLIC_TOKEN=
#
# Альтернатива: NEXT_PUBLIC_MAPBOX_TOKEN — вшивается в клиентский бандл при `npm run build` /
# `docker compose build frontend`; после смены токена нужна пересборка образа.
# NEXT_PUBLIC_MAPBOX_TOKEN=
#
# Docker Compose уже подключает env_file: ./frontend/.env.local — положите туда MAPBOX_PUBLIC_TOKEN=pk...
#
# ПРОДАКШЕН (nginx): запросы к /api/* идут в Laravel, не в Next.js. Эндпоинт GET /api/business/mapbox-config
# читает токен из backend/.env — продублируйте тот же ключ:
#   MAPBOX_PUBLIC_TOKEN=pk....
# (см. backend/config/services.php и маршрут в routes/api.php)
#
# Опционально: свои стили; иначе streets-v12 / dark-v11 по теме приложения.
# NEXT_PUBLIC_MAPBOX_STYLE_LIGHT=mapbox://styles/mapbox/streets-v12
# NEXT_PUBLIC_MAPBOX_STYLE_DARK=mapbox://styles/mapbox/dark-v11
