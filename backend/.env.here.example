# Скопируйте строки в backend/.env (файл .env в git не коммитится).
#
# Mapbox (публичный pk) — для GET /api/business/mapbox-config (карта маршрутов в бизнес-админке).
# Должен совпадать с MAPBOX_PUBLIC_TOKEN / NEXT_PUBLIC_MAPBOX_TOKEN у фронта.
# MAPBOX_PUBLIC_TOKEN=
# HERE REST API: в приложении используется только API key (см. config/services.php).
# App ID из консоли HERE для бэкенда не задаётся — достаточно ключа.

HERE_API_KEY=
HERE_API_URL=https://router.hereapi.com
HERE_GEOCODE_URL=https://geocode.search.hereapi.com
# Для США оставьте как ниже (формат HERE Geocode Search `in`, не просто «USA»).
HERE_GEOCODE_IN=countryCode:USA

# OpenAI: маршрутный ассистент (см. config/services.php: services.openai.model)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Очередь: для OptimizeRouteJob и прочих джобов нужен worker (в Docker — сервис `queue` в docker-compose.yml).
# QUEUE_CONNECTION=database
# После миграции `failed_jobs`: команда `php artisan queue:failed` показывает упавшие джобы.
